NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://tanaw_user:tanaw_password@localhost:5432/tanaw_db
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_TTL_SECONDS=604800
